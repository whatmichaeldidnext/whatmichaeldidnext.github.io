---
import {
  MainLayout,
  BaseLayout,
  SectionHeader,
  Card,
  Badge,
  FeaturedProjects
} from "../components";
import { getGraph } from "../lib/contentGraph.js";

const graph = await getGraph();

const skills = graph.content.skills;

const getProjectsForSkill = (skillId) =>
  graph.projectsFor("skills", skillId);
---

<BaseLayout
  title="Skills | Michael Charles Portfolio"
  description="Explore the technical and professional skills evidenced throughout Michael Charles' projects."
>

<MainLayout>

<section class="skills-page">

  <SectionHeader
    eyebrow="Evidence-Based Skills"
    title="Skills"
    intro="Rather than listing isolated keywords, each skill is supported by the projects that demonstrate it in practice."
  />

  <div class="skills-grid">

    {skills.map((skill) => {

      const evidenceProjects = getProjectsForSkill(skill.id);

      return (

        <Card href={`/skills/${skill.id}`}>

          <h2>{skill.name}</h2>

          <p>
            Demonstrated across real projects, technical decisions and delivery outcomes.
          </p>

          <div class="meta-section">

            <h3>Evidence</h3>

            <div class="badge-list">

              {evidenceProjects.map(project => (

                <Badge tone="green">
                  {project.title}
                </Badge>

              ))}

            </div>

          </div>

          <span class="explore-link">
            Explore →
          </span>

        </Card>

      );

    })}

  </div>

</section>

</MainLayout>

</BaseLayout>

<style>

.skills-page{
    max-width:1200px;
}

.skills-grid{

    display:grid;

    grid-template-columns:
        repeat(auto-fit,minmax(320px,1fr));

    gap:1.5rem;

    margin-top:2rem;

}

.skills-grid h2{

    margin-top:0;

}

.meta-section{

    margin-top:1.5rem;

}

.meta-section h3{

    margin-bottom:.5rem;

    color:#cbd5e1;

    font-size:.95rem;

}

.badge-list{

    display:flex;

    flex-wrap:wrap;

    gap:.5rem;

}

.explore-link{

    display:inline-block;

    margin-top:1.5rem;

    color:#93c5fd;

    font-weight:700;

}

</style>