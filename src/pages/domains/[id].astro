---
import {
  MainLayout,
  BaseLayout,
} from "../../components";
import { getGraph } from "../../lib/contentGraph.js";

export async function getStaticPaths() {
  const graph = await getGraph();

  return graph.getNodes("domains").map((node) => ({
    params: { id: node.id },
    props: { domain: node.data },
  }));
}

const { domain } = Astro.props;
const graph = await getGraph();

const relatedProjects = graph.projectsFor("domains", domain.id);
const relatedSkills = graph.skillsFor("domains", domain.id);
---

<BaseLayout title={`${domain.name} | Michael Charles Portfolio`}>
  <MainLayout>
    <a href="/domains" class="back-link">← Back to Domains</a>

    <article class="detail-page">
      <h1>{domain.name}</h1>

      <p class="summary">{domain.description}</p>

      <section>
        <h2>Related Projects</h2>
        <ul>
          {relatedProjects.map((project) => (
            <li>
              <a href={`/projects/${project.id}`}>{project.title}</a>
            </li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Related Skills</h2>
        <ul>
          {relatedSkills.map((skill) => (
            <li>
              <a href={`/skills/${skill.id}`}>{skill.name}</a>
            </li>
          ))}
        </ul>
      </section>
    </article>
  </MainLayout>
</BaseLayout>