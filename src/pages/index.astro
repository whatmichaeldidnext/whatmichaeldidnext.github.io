---
import {
  BaseLayout,
  MainLayout,
  HeroSection,
  SummarySection,
  CurrentlyBuilding,
  DomainGrid,
  FeaturedProjects,
  GraphPreview,
  InsightsPreview
} from "../components";

import { getCollection } from "astro:content";

const insights = (await getCollection("blog"))
  .filter((post) => post.data.visibility !== "private")
  .filter((post) => !post.data.published || new Date(post.data.published) <= new Date())
  .sort((a, b) => new Date(b.data.published ?? 0).getTime() - new Date(a.data.published ?? 0).getTime())
  .slice(0, 3);
---

<BaseLayout
  title="What Michael Did Next | An Interactive Portfolio of Experience, Interests and Skills"
  description="Explore Michael Charles' interactive professional portfolio across project delivery, telecoms, data analytics, cybersecurity, software development and architecture."
>
  <MainLayout>
    <section class="hero-graph">
      <HeroSection />
      <GraphPreview />
    </section>

    <SummarySection />
    <InsightsPreview />
    <CurrentlyBuilding />
    <DomainGrid />
    <FeaturedProjects />

  </MainLayout>
</BaseLayout>

<style>
  .hero-graph {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: stretch;
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  @media (max-width: 900px) {
    .hero-graph {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>