---
import BaseLayout from "../layouts/BaseLayout.astro";
import MainLayout from "../layouts/MainLayout.astro";

import HeroSection from "../components/Home/HeroSection.astro";
import SummarySection from "../components/Home/SummarySection.astro";
import CurrentlyBuilding from "../components/Home/CurrentlyBuilding.astro";
import DomainGrid from "../components/Home/DomainGrid.astro";
import FeaturedProjects from "../components/Home/FeaturedProjects.astro";
import GraphPreview from "../components/Home/GraphPreview.astro";
---

<BaseLayout
  title="What Michael Did Next | An Interactive Portfolio of Experience, Interests and Skills"
  description="Explore Michael Charles' interactive professional portfolio across project delivery, telecoms, data analytics, cybersecurity, software development and architecture."
>
  <MainLayout>
    <section class="hero-graph">
        <HeroSection />
        <GraphPreview />
    </section>
    <SummarySection />
    <CurrentlyBuilding />
    <DomainGrid />
    <FeaturedProjects />
  </MainLayout>
</BaseLayout>

<style>
  .hero-graph {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(360px, 0.9fr);
    gap: 2rem;
    align-items: center;
    padding: 3rem 0;
  }

  @media (max-width: 900px) {
    .hero-graph {
      grid-template-columns: 1fr;
    }
  }
</style>