---
import {
  BaseLayout,
  MainLayout,
  SectionHeader,
  HeroSection,
  SummarySection,
  CurrentlyBuilding,
  DomainGrid,
  FeaturedProjects,
  GraphPreview
} from "../components";
---

<BaseLayout
  title="What Michael Did Next | An Interactive Portfolio of Experience, Interests and Skills"
  description="Explore Michael Charles' interactive professional portfolio across project delivery, telecoms, data analytics, cybersecurity, software development and architecture."
>
  <MainLayout>
    <section class="hero-graph">
        <HeroSection />
        <GraphPreview />
    </section>
    <SummarySection />
    <CurrentlyBuilding />
    <DomainGrid />
    <FeaturedProjects />
  </MainLayout>
</BaseLayout>

<style>
  .hero-graph {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(360px, 0.9fr);
    gap: 2rem;
    align-items: center;
    padding: 3rem 0;
  }

  @media (max-width: 900px) {
    .hero-graph {
      grid-template-columns: 1fr;
    }
  }
</style>