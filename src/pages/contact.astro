---
import BaseLayout from "../layouts/BaseLayout.astro";
import MainLayout from "../layouts/MainLayout.astro";

import SectionHeader from "../components/Common/SectionHeader.astro";
import Card from "../components/Common/Card.astro";
---

<BaseLayout
  title="Contact | Michael Charles"
  description="Get in touch with Michael Charles about technical delivery, data-led transformation, cybersecurity, software development and portfolio opportunities."
>
  <MainLayout>
    <section class="contact-page">
      <SectionHeader
        eyebrow="Let's Talk"
        title="Get in Touch"
        intro="Whether you're looking for a project manager, product owner, technical consultant or simply want to discuss an interesting challenge, I'd be pleased to hear from you."
      />

      <div class="contact-grid">
        <Card>
          <h2>What I'd love to talk about</h2>

          <p>
            Digital transformation, technical delivery, cybersecurity, software
            engineering, data analytics, architecture, or any challenge that sits
            between technology, people and business outcomes.
          </p>
        </Card>

        <Card>
          <h2>Contact Details</h2>

          <ul class="contact-list">
            <li>
              <strong>Email</strong>
              <a href="mailto:hello@what-michael-did-next.co.uk">
                hello@what-michael-did-next.co.uk
              </a>
            </li>

            <li>
              <strong>LinkedIn</strong>
              <a
                href="https://www.linkedin.com/in/what-michael-did-next/"
                target="_blank"
                rel="noopener noreferrer"
              >
                @what-michael-did-next
              </a>
            </li>

            <li>
              <strong>GitHub</strong>
              <a
                href="https://github.com/whatmichaeldidnext"
                target="_blank"
                rel="noopener noreferrer"
              >
                @whatmichaeldidnext
              </a>
            </li>
          </ul>
        </Card>
      </div>
    </section>
  </MainLayout>
</BaseLayout>

<style>
  .contact-page {
    max-width: 980px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contact-list li {
    display: grid;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
  }

  .contact-list li:last-child {
    margin-bottom: 0;
  }

  .contact-list strong {
    color: #f8fafc;
  }

  .contact-list a {
    color: #93c5fd;
    text-decoration: none;
    overflow-wrap: anywhere;
  }

  .contact-list a:hover {
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>