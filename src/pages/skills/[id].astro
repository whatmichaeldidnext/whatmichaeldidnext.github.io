---
import {
  MainLayout,
  BaseLayout,
} from "../../components";

import { getGraph } from "../../lib/contentGraph.js";

export async function getStaticPaths() {
  const graph = await getGraph();

  return graph.getNodes("skills").map((node) => ({
    params: { id: node.id },
    props: { skill: node.data },
  }));
}

const { skill } = Astro.props;
const graph = await getGraph();

const relatedProjects = graph.projectsFor("skills", skill.id);
const relatedDomains = graph.domainsFor("skills", skill.id);
---

<BaseLayout title={`${skill.name} | Michael Charles Portfolio`}>
  <MainLayout>
    <a href="/skills" class="back-link">← Back to Skills</a>

    <article class="detail-page">
      <h1>{skill.name}</h1>

      <p class="summary">
        This skill is evidenced through the projects and domains below.
      </p>

      <section>
        <h2>Evidence Projects</h2>

        {relatedProjects.length > 0 ? (
          <ul>
            {relatedProjects.map((project) => (
              <li>
                <a href={`/projects/${project.id}`}>
                  {project.title}
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p>No projects currently reference this skill.</p>
        )}
      </section>

      <section>
        <h2>Related Domains</h2>

        {relatedDomains.length > 0 ? (
          <ul>
            {relatedDomains.map((domain) => (
              <li>
                <a href={`/domains/${domain.id}`}>
                  {domain.name}
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p>No related domains found.</p>
        )}
      </section>
    </article>
  </MainLayout>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
  }

  .detail-page {
    max-width: 800px;
  }

  .summary {
    font-size: 1.2rem;
    color: #cbd5e1;
  }

  section {
    margin-top: 2rem;
  }

  h1 {
    color: #bfdbfe;
  }
</style>