---
import BaseLayout from "../layouts/BaseLayout.astro";
import MainLayout from "../layouts/MainLayout.astro";
import ExperienceGraph from "../components/Graph/ExperienceGraph.astro";
---
<BaseLayout title="Experience Graph | Michael Charles Portfolio">
<MainLayout>
  <h1>Experience Graph</h1>

  <p>
    Explore how my projects, skills, domains and tools connect. Search, highlight, or double-click a node to open its page.
  </p>

  <ExperienceGraph />
</MainLayout>
</BaseLayout>

<style>
  .graph-page {
    width: min(100%, 1600px);
    margin-inline: auto;
  }
</style>