---
import {
  BaseLayout,
  MainLayout,
  SectionHeader,
  Card,
  Badge,
  Button
} from "../components";

import { getGraph } from "../lib/contentGraph.js";

const graph = await getGraph();

const domains = graph.content.domains;
const skills = graph.content.skills;

const getProjectsForDomain = (domainId) =>
  graph.projectsFor("domains", domainId);
---

<BaseLayout
  title="Domains | Michael Charles Portfolio"
  description="Explore the professional domains that connect Michael Charles' experience."
>

<MainLayout>

<section class="domains-page">

  <SectionHeader
    eyebrow="Professional Domains"
    title="How My Experience Connects"
    intro="These domains represent the disciplines that have shaped my career. They aren't isolated skills—they overlap through projects, technologies and real-world outcomes."
  />

  <div class="domain-grid">

    {domains.map((domain) => {

      const relatedProjects = getProjectsForDomain(domain.id);

      return (

        <Card href={`/domains/${domain.slug}`}>

          <h2>{domain.name}</h2>

          <p>{domain.description}</p>

          <div class="domain-footer">

            <Badge tone="blue">
              {relatedProjects.length} project{relatedProjects.length !== 1 && "s"}
            </Badge>

            <span class="explore-link">
              Explore →
            </span>

          </div>

        </Card>

      );

    })}

  </div>

</section>

</MainLayout>

</BaseLayout>

<style>

.domains-page{
    max-width:1200px;
}

.domain-grid{

    display:grid;

    grid-template-columns:
        repeat(auto-fit,minmax(320px,1fr));

    gap:1.5rem;

    margin-top:2rem;

}

.domain-grid h2{

    margin-top:0;

}

.domain-footer{

    display:flex;

    justify-content:space-between;

    align-items:center;

    margin-top:1.5rem;

}

.explore-link{

    color:#93c5fd;

    font-weight:600;

}

</style>