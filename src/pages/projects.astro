---
import {
  MainLayout,
  BaseLayout,
  SectionHeader,
  Card,
  Badge
} from "../components";
import { getGraph } from "../lib/contentGraph.js";

const graph = await getGraph();

const projects = graph.content.projects;
const domains = graph.content.domains;
const skills = graph.content.skills;

const getDomainName = (id) =>
  graph.find("domains", id)?.name ?? id;

const getSkillName = (id) =>
  graph.find("skills", id)?.name ?? id;
---

<BaseLayout
  title="Projects | Michael Charles Portfolio"
  description="Explore evidence-led project summaries showing how Michael Charles' experience connects across delivery, data, software, cybersecurity and architecture."
>
  <MainLayout>
    <section class="projects-page">
      <SectionHeader
        eyebrow="Evidence Library"
        title="Projects"
        intro="Evidence-led project summaries showing how different parts of my experience connect through real delivery, technical decisions, outcomes and lessons learned."
      />

      <div class="project-grid">
        {projects.map((project) => (
          <Card href={`/projects/${project.id}`}>
            <h2>{project.title}</h2>

            <p>
              {project.summary ?? "Project summary coming soon."}
            </p>

            <div class="meta-section">
              <h3>Domains</h3>

              <div class="badge-list">
                {project.domains.map((domainId) => (
                  <Badge tone="blue">
                    {getDomainName(domainId)}
                  </Badge>
                ))}
              </div>
            </div>

            <div class="meta-section">
              <h3>Skills</h3>

              <div class="badge-list">
                {project.skills.map((skillId) => (
                  <Badge>
                    {getSkillName(skillId)}
                  </Badge>
                ))}
              </div>
            </div>

            <span class="explore-link">Open project →</span>
          </Card>
        ))}
      </div>
    </section>
  </MainLayout>
</BaseLayout>

<style>
  .projects-page {
    max-width: 1200px;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .project-grid h2 {
    margin-top: 0;
  }

  .project-grid p {
    margin-bottom: 1.25rem;
  }

  .meta-section {
    margin-top: 1.25rem;
  }

  .meta-section h3 {
    margin-bottom: 0.5rem;
    color: #cbd5e1;
    font-size: 0.95rem;
  }

  .badge-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .explore-link {
    display: inline-block;
    margin-top: 1.5rem;
    color: #93c5fd;
    font-weight: 700;
  }
</style>