---
import {
  SectionHeader,
  Card
} from "../../components";
import { getGraph } from "../../lib/contentGraph.js";

const graph = await getGraph();

const domains = graph.content.domains;
const featuredDomains = domains.filter((domain) =>
  domain.featured
  );
---

<section class="domains-section">

  <SectionHeader
    eyebrow="Professional Domains"
    title="Explore My Experience"
    intro="These domains represent the disciplines that have shaped my career. Rather than existing in isolation, they connect through projects, technologies and outcomes."
  />

  <div class="domains-header">
    <span></span>

    <a href="/domains">
      View all domains →
    </a>
  </div>

  <div class="domain-grid">

    {featuredDomains.map((domain) => (

      <Card
        href={`/domains/${domain.slug}`}
      >

        <h3>{domain.name}</h3>

        <p>{domain.description}</p>

      </Card>

    ))}

  </div>

</section>

<style>

.domains-section{
    padding:3rem 0;
    border-top:1px solid #334155;
}

.domains-header{
    display:flex;
    justify-content:flex-end;
    margin-bottom:1.5rem;
}

.domains-header a{
    color:#93c5fd;
    text-decoration:none;
}

.domain-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1rem;
  margin-top: 2rem;
}

@media (max-width: 1200px) {
  .domain-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 850px) {
  .domain-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 550px) {
  .domain-grid {
    grid-template-columns: 1fr;
  }
}
.domain-grid h3{
    margin-top:0;
}

</style>