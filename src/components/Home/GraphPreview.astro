---
---

<aside class="graph-preview-card">
  <svg
    class="mini-graph"
    viewBox="0 0 420 280"
    role="img"
    aria-label="Preview of connected portfolio graph"
  >
    <g class="graph-lines">
      <line x1="210" y1="130" x2="90" y2="65" />
      <line x1="210" y1="130" x2="330" y2="65" />
      <line x1="210" y1="130" x2="105" y2="215" />
    </g>

    <g class="node domain">
      <circle cx="90" cy="65" r="36" />
      <text x="90" y="70">Domain</text>
    </g>

    <g class="node skill">
      <circle cx="330" cy="65" r="36" />
      <text x="330" y="70">Skill</text>
    </g>

    <g class="node project">
      <rect x="160" y="100" width="100" height="60" rx="12" />
      <text x="210" y="135">Project</text>
    </g>

    <g class="node tool" transform="translate(105 215)">
      <rect x="-28" y="-28" width="56" height="56" transform="rotate(45)" />
      <text x="0" y="5">Tool</text>
    </g>
  </svg>

  <p>
    Explore how projects, domains, skills and tools connect through an
    interactive graph-driven view.
  </p>
</aside>

<style>
  .graph-preview-card {
    position: relative;
    overflow: hidden;
    border: 1px solid #334155;
    border-radius: 18px;
    background: #020617;
    padding: 1.5rem;
    height: 100%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .mini-graph {
    width: 100%;
    max-width: 460px;
    aspect-ratio: 3 / 2;
    margin: 0 auto 1.5rem;
    display: block;
  }

  .graph-lines line {
    stroke: #334155;
    stroke-width: 2;
  }

  .node circle,
  .node rect {
    fill: #0f172a;
    stroke-width: 2.5;
  }

  .node text {
    fill: #e5e7eb;
    font-size: 13px;
    font-weight: 700;
    text-anchor: middle;
    dominant-baseline: middle;
    pointer-events: none;
  }

  .project rect {
    stroke: #60a5fa;
  }

  .domain circle {
    stroke: #a78bfa;
  }

  .skill circle {
    stroke: #34d399;
  }

  .tool rect {
    stroke: #fbbf24;
  }

  .graph-preview-card p {
    color: #cbd5e1;
    line-height: 1.6;
    margin: 0;
  }
</style>