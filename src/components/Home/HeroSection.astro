---
import HeroHeader from "../Common/HeroHeader.astro";
import Button from "../Common/Button.astro";
---

<section class="hero">

  <HeroHeader
    eyebrow="Explorable Professional Profile"
    title="Michael Charles"
    intro="Connecting project delivery, product ownership, data analytics, cybersecurity, software engineering and technical architecture through real projects, evidence and outcomes."
  >

  <div class="hero-actions">
    <Button href="/graph">
      Experience Graph
    </Button>

    <Button
      href="/projects"
      variant="secondary"
    >
      View Projects
    </Button>
  </div>

  </HeroHeader>

</section>

<style>
.hero {
    display:flex;
    flex-direction:column;
    height:100%;
}
.hero-actions{
    margin-top:auto;

    display:flex;
    gap:1rem;
    flex-wrap:wrap;
}
.graph-preview-card{
    height:100%;
    display:flex;
    flex-direction:column;
}
</style>