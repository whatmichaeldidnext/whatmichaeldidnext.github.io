---
import {
  SectionHeader,
  Card
} from "../../components";
import { getGraph } from "../../lib/contentGraph.js";

const graph = await getGraph();

const featuredProjects = graph.content.projects.filter((project) =>
  project.featured
);
---

<section class="featured-projects-section">
  <div class="projects-heading">
    <SectionHeader
      eyebrow="Selected Evidence"
      title="Featured Projects"
      intro="A small selection of projects that show how my experience connects across delivery, data, software, cybersecurity, and systems thinking."
    />

    <a href="/projects">View all projects →</a>
  </div>

  <div class="project-grid">
    {featuredProjects.map((project) => (
      <Card href={`/projects/${project.slug}`}>
        <h3>{project.title}</h3>
        <p>{project.summary ?? "Project summary coming soon."}</p>
      </Card>
    ))}
  </div>
</section>

<style>
  .featured-projects-section {
    padding: 3rem 0;
    border-top: 1px solid #334155;
  }

  .projects-heading {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: flex-start;
  }

  .projects-heading a {
    color: #93c5fd;
    text-decoration: none;
    white-space: nowrap;
    margin-top: 0.4rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .project-grid h3 {
    color: #e5e7eb;
    margin-top: 0;
  }

  .project-grid p {
    color: #cbd5e1;
    line-height: 1.6;
  }

  @media (max-width: 700px) {
    .projects-heading {
      display: block;
    }

    .projects-heading a {
      display: inline-block;
      margin-bottom: 1.5rem;
    }
  }
</style>