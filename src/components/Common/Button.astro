---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
}

const { href, variant = "primary" } = Astro.props;
---

<a href={href} class={`button ${variant}`}>
  <slot />
</a>

<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1rem;
    border-radius: 8px;
    font-weight: 700;
    text-decoration: none;
  }

  .primary {
    background: #2563eb;
    color: white;
  }

  .secondary {
    border: 1px solid #334155;
    color: #bfdbfe;
  }
</style>