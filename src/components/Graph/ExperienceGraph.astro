---
import projects from "../../content/projects.json";
import domains from "../../content/domains.json";
import skills from "../../content/skills.json";
import tools from "../../content/tools.json";
import technologies from "../../content/technologies.json";
import thinking from "../../content/thinking.json";
import artifacts from "../../content/artifacts.json";
import qualifications from "../../content/qualifications.json";

const graphData = {
  projects,
  domains,
  skills,
  tools,
  technologies,
  thinking,
  artifacts,
  qualifications,
};
---

<div class="graph-wrapper">
  <div class="graph-panel-header">
    <div class="graph-controls">
      <label for="graph-search">Search the graph</label>
      <input
        id="graph-search"
        type="search"
        placeholder="Search projects, domains, skills or tools..."
      />
    </div>

    <div class="graph-legend" aria-label="Graph legend">
      <span><i class="legend-dot legend-project"></i>Project</span>
      <span><i class="legend-dot legend-domain"></i>Domain</span>
      <span><i class="legend-dot legend-skill"></i>Skill</span>
      <span><i class="legend-dot legend-tool"></i>Tool</span>
      <span><i class="legend-dot legend-technology"></i>Technology</span>
      <span><i class="legend-dot legend-thinking"></i>Thinking</span>
      <span><i class="legend-dot legend-artifact"></i>Evidence</span>
      <span><i class="legend-dot legend-qualification"></i>Qualification</span>
    </div>
  </div>

  <div id="experience-graph"></div>

  <aside id="graph-popup" class="graph-popup hidden" aria-live="polite">
    <button id="graph-popup-close" class="graph-popup-close" type="button">
      ×
    </button>

    <div id="graph-popup-content">
      <p class="panel-eyebrow">Selected item</p>
      <h2>Nothing selected</h2>
      <p>Click a node in the graph to see more detail.</p>
    </div>
  </aside>
</div>

<script
  id="graph-data"
  type="application/json"
  set:html={JSON.stringify(graphData)}
></script>

<script>
  import cytoscape from "cytoscape";
  import fcose from "cytoscape-fcose";

  cytoscape.use(fcose);

  const graphDataElement = document.getElementById("graph-data");
  const graphContainer = document.getElementById("experience-graph");
  const searchInput = document.getElementById("graph-search");
  const popup = document.getElementById("graph-popup");
  const popupContent = document.getElementById("graph-popup-content");
  const popupClose = document.getElementById("graph-popup-close");

  if (
    graphDataElement &&
    graphContainer &&
    searchInput &&
    popup &&
    popupContent &&
    popupClose
  ) {
    const graphData = JSON.parse(graphDataElement.textContent);
    const elements = [];

    const addNode = (type, item, labelKey = "name") => {
      elements.push({
        data: {
          id: `${type}-${item.id}`,
          label: item[labelKey],
          type,
        },
      });
    };

    const addEdge = (source, target, relationship = "related-to") => {
      elements.push({
        data: {
          source,
          target,
          relationship,
        },
      });
    };

    graphData.domains.forEach((domain) => addNode("domain", domain));
    graphData.skills.forEach((skill) => addNode("skill", skill));
    graphData.tools.forEach((tool) => addNode("tool", tool));
    graphData.technologies.forEach((technology) =>
      addNode("technology", technology)
    );
    graphData.thinking.forEach((theme) => addNode("thinking", theme));
    graphData.artifacts.forEach((artifact) => addNode("artifact", artifact));
    graphData.qualifications.forEach((qualification) =>
      addNode("qualification", qualification)
    );

    const projectExists = (projectId) =>
      graphData.projects.some((project) => project.id === projectId);

    const normaliseProjectId = (projectId) =>
      projectId?.replace(/^project-/, "");

    graphData.projects.forEach((project) => {
      addNode("project", project, "title");

      project.domains?.forEach((domainId) =>
        addEdge(`project-${project.id}`, `domain-${domainId}`)
      );

      project.skills?.forEach((skillId) =>
        addEdge(`project-${project.id}`, `skill-${skillId}`)
      );

      project.tools?.forEach((toolId) =>
        addEdge(`project-${project.id}`, `tool-${toolId}`)
      );

      project.technologies?.forEach((technologyId) =>
        addEdge(`project-${project.id}`, `technology-${technologyId}`)
      );

      project.thinking?.forEach((thinkingId) =>
        addEdge(`project-${project.id}`, `thinking-${thinkingId}`)
      );

      project.artifacts?.forEach((artifactId) =>
        addEdge(`project-${project.id}`, `artifact-${artifactId}`)
      );

      project.qualifications?.forEach((qualificationId) =>
        addEdge(`project-${project.id}`, `qualification-${qualificationId}`)
      );

      const parentProjectId = normaliseProjectId(project.parentProject);

      if (parentProjectId && projectExists(parentProjectId)) {
        addEdge(
          `project-${project.id}`,
          `project-${parentProjectId}`,
          "part-of"
        );
      }

      const dependencies = Array.isArray(project.dependsOn)
        ? project.dependsOn
        : project.dependsOn
          ? [project.dependsOn]
          : [];

      dependencies.forEach((dependencyId) => {
        const cleanDependencyId = normaliseProjectId(dependencyId);

        if (!cleanDependencyId || !projectExists(cleanDependencyId)) return;

        addEdge(
          `project-${project.id}`,
          `project-${cleanDependencyId}`,
          "depends-on"
        );
      });
    });

    const graphStyle = [
      {
        selector: "node",
        style: {
          label: "data(label)",
          color: "#e5e7eb",
          "background-color": "#0f172a",
          "border-width": 2,
          "border-color": "#475569",
          "font-size": "9px",
          width: "56px",
          height: "56px",
          "text-valign": "center",
          "text-halign": "center",
          "text-wrap": "wrap",
          "text-max-width": "72px",
          "text-overflow-wrap": "anywhere",
          "line-height": 1.15,
          cursor: "pointer",
        },
      },
      {
        selector: 'node[type = "project"]',
        style: {
          shape: "round-rectangle",
          "border-color": "#60a5fa",
          width: "160px",
          height: "92px",
          "font-size": "12px",
          "text-max-width": "112px",
        },
      },
      {
        selector: 'node[type = "domain"]',
        style: {
          shape: "hexagon",
          "border-color": "#a78bfa",
          width: "92px",
          height: "92px",
          "font-size": "11px",
          "text-max-width": "82px",
        },
      },
      {
        selector: 'node[type = "skill"]',
        style: {
          shape: "ellipse",
          "border-color": "#34d399",
          width: "72px",
          height: "72px",
          "font-size": "10px",
          "text-max-width": "64px",
        },
      },
      {
        selector: 'node[type = "tool"]',
        style: {
          shape: "diamond",
          "border-color": "#fbbf24",
          width: "64px",
          height: "64px",
          "font-size": "8px",
          "text-max-width": "58px",
        },
      },
      {
        selector: 'node[type = "technology"]',
        style: {
          shape: "round-rectangle",
          "border-color": "#22d3ee",
          width: "84px",
          height: "52px",
          "font-size": "8px",
          "text-max-width": "76px",
        },
      },
      {
        selector: 'node[type = "thinking"]',
        style: {
          shape: "ellipse",
          "border-color": "#f472b6",
          width: "82px",
          height: "62px",
          "font-size": "9px",
          "text-max-width": "74px",
        },
      },
      {
        selector: 'node[type = "artifact"]',
        style: {
          shape: "round-tag",
          "border-color": "#cbd5e1",
          width: "88px",
          height: "54px",
          "font-size": "8px",
          "text-max-width": "78px",
        },
      },
      {
        selector: 'node[type = "qualification"]',
        style: {
          shape: "octagon",
          "border-color": "#fb7185",
          width: "86px",
          height: "86px",
          "font-size": "10px",
          "text-max-width": "76px",
        },
      },
      {
        selector: "edge",
        style: {
          width: 2,
          "line-color": "#334155",
          "curve-style": "bezier",
          opacity: 0.7,
        },
      },
      {
        selector: 'edge[relationship = "depends-on"]',
        style: {
          "line-style": "dashed",
          "line-color": "#64748b",
          "target-arrow-shape": "triangle",
          "target-arrow-color": "#64748b",
          "curve-style": "bezier",
          width: 2
        }
      },
      {
        selector: 'edge[relationship = "part-of"]',
        style: {
          "line-style": "dotted",
          "line-color": "#94a3b8",
          width: 2
        }
      },
      {
        selector: ".faded",
        style: {
          opacity: 0.15,
        },
      },
      {
        selector: ".highlighted",
        style: {
          opacity: 1,
          "border-width": 4,
          "shadow-blur": 20,
          "shadow-opacity": 0.4,
          "shadow-color": "#ffffff",
        },
      },
      {
        selector: ".search-match",
        style: {
          "border-width": 5,
          "border-color": "#38bdf8",
          "shadow-blur": 25,
          "shadow-opacity": 0.6,
          "shadow-color": "#38bdf8",
        },
      },
    ];

    const layoutOptions = {
      name: "fcose",
      animate: true,
      randomize: false,
      fit: true,
      padding: 180,
      quality: "proof",

      nodeRepulsion: (node) => {
        switch (node.data("type")) {
          case "project":
            return 600000;
          case "domain":
            return 300000;
          case "skill":
            return 240000;
          case "thinking":
            return 220000;
          case "technology":
            return 180000;
          case "tool":
            return 150000;
          case "artifact":
            return 120000;
          case "qualification":
            return 180000;
          default:
            return 150000;
        }
      },

      idealEdgeLength: 360,
      edgeElasticity: 0.08,
      nodeSeparation: 220,
      nestingFactor: 1.2,
      gravity: 0.002,
      gravityRangeCompound: 1.5,
      avoidOverlap: true,
      avoidOverlapPadding: 55,
    };

    const cy = cytoscape({
      container: graphContainer,
      elements,
      style: graphStyle,
      layout: layoutOptions,
    });

    const typeAnchors = {
      project: { x: 0.5, y: 0.5 },
      qualification: { x: 0.5, y: 0.16 },
      domain: { x: 0.18, y: 0.32 },
      skill: { x: 0.82, y: 0.32 },
      artifact: { x: 0.16, y: 0.72 },
      thinking: { x: 0.38, y: 0.78 },
      technology: { x: 0.64, y: 0.78 },
      tool: { x: 0.84, y: 0.7 },
    };

    const applyPreferredPositions = () => {
      const width = graphContainer.clientWidth;
      const height = graphContainer.clientHeight;

      cy.nodes().forEach((node) => {
        const type = node.data("type");
        const anchor = typeAnchors[type];

        if (!anchor) return;

        const jitter = type === "project" ? 500 : 350;

        node.position({
          x: width * anchor.x + (Math.random() - 0.5) * jitter,
          y: height * anchor.y + (Math.random() - 0.5) * jitter,
        });
      });
    };

    const positionProjectsOnCircle = () => {
      const width = graphContainer.clientWidth;
      const height = graphContainer.clientHeight;

      const centreX = width / 2;
      const centreY = height / 2;

      const projects = cy.nodes('[type = "project"]');

      const radius = Math.max(width, height) * 1.5;

      projects.forEach((node, index) => {
        const angle =
          ((Math.PI * 2) / projects.length) * index - Math.PI / 2;

        node.position({
          x: centreX + Math.cos(angle) * radius,
          y: centreY + Math.sin(angle) * radius,
        });

        node.lock();
      });
    };

    const pullSharedNodesTowardProjects = () => {
      const groups = new Map();

      cy.nodes().forEach((node) => {
        if (node.data("type") === "project") return;

        const connectedProjects = node
          .connectedEdges()
          .connectedNodes()
          .filter((connectedNode) => connectedNode.data("type") === "project");

        if (connectedProjects.length === 0) return;

        const projectIds = connectedProjects
          .map((projectNode) => projectNode.id())
          .sort();

        const groupKey = projectIds.join("|");

        if (!groups.has(groupKey)) {
          groups.set(groupKey, {
            projects: connectedProjects,
            nodes: [],
          });
        }

        groups.get(groupKey).nodes.push(node);
      });

      groups.forEach((group) => {
        const average = group.projects.reduce(
          (acc, projectNode) => {
            const position = projectNode.position();

            return {
              x: acc.x + position.x,
              y: acc.y + position.y,
            };
          },
          { x: 0, y: 0 }
        );

        const centroid = {
          x: average.x / group.projects.length,
          y: average.y / group.projects.length,
        };

        const count = group.nodes.length;

        group.nodes.forEach((node, index) => {
          const angle = ((Math.PI * 2) / count) * index;

          const baseRadius = 100;
          const nodeSpacing = 85;

          const radius =
            count === 1
              ? 0
              : Math.min(750, baseRadius + Math.sqrt(count) * nodeSpacing);

          node.animate({
            position: {
              x: centroid.x + Math.cos(angle) * radius,
              y: centroid.y + Math.sin(angle) * radius,
            },
            duration: 500,
          });
        });
      });
    };

    const runLayout = () => {
      positionProjectsOnCircle();

      const layout = cy.layout({
        ...layoutOptions,

        fixedNodeConstraint: cy
          .nodes('[type = "project"]')
          .map((n) => ({
            nodeId: n.id(),
            position: n.position(),
          })),
      });

      layout.run();

      layout.on("layoutstop", () => {
        pullSharedNodesTowardProjects();
      });
    };

    cy.ready(() => {
      runLayout();
      cy.fit(undefined, 250);
      cy.center();
    });

    const resizeGraph = () => {
      cy.resize();
      cy.fit(undefined, 250);
    };

    const fitGraph = () => {
      cy.resize();
      cy.fit(undefined, 250);
      cy.center();
    };

    const graphResizeObserver = new ResizeObserver(() => {
      resizeGraph();
    });

    graphResizeObserver.observe(graphContainer);

    window.addEventListener("resize", resizeGraph);

    document.addEventListener("sidebar-toggle", () => {
      window.setTimeout(fitGraph, 300);
    });

    const updateLabelSizes = () => {
      const zoom = cy.zoom();

      cy.nodes().forEach((node) => {
        const type = node.data("type");

        let baseSize = 9;

        if (type === "project") baseSize = 12;
        if (type === "domain") baseSize = 11;
        if (type === "skill") baseSize = 10;
        if (type === "tool") baseSize = 8;
        if (type === "technology") baseSize = 8;
        if (type === "thinking") baseSize = 9;
        if (type === "artifact") baseSize = 8;
        if (type === "qualification") baseSize = 10;

        const adjustedSize = Math.max(7, Math.min(16, baseSize / zoom));

        node.style("font-size", adjustedSize);
      });
    };

    cy.on("zoom", updateLabelSizes);
    cy.on("layoutstop", updateLabelSizes);

    updateLabelSizes();

    const findProject = (id) =>
      graphData.projects.find((item) => item.id === id);

    const findDomain = (id) =>
      graphData.domains.find((item) => item.id === id);

    const findSkill = (id) =>
      graphData.skills.find((item) => item.id === id);

    const findTool = (id) =>
      graphData.tools.find((item) => item.id === id);

    const findTechnology = (id) =>
      graphData.technologies.find((item) => item.id === id);

    const findThinking = (id) =>
      graphData.thinking.find((item) => item.id === id);

    const findArtifact = (id) =>
      graphData.artifacts.find((item) => item.id === id);

    const findQualification = (id) =>
      graphData.qualifications.find((item) => item.id === id);

    const listHtml = (items, getUrl = null) => {
      if (!items || items.length === 0) {
        return "<p class='empty-list'>None yet.</p>";
      }

      return `
        <ul>
          ${items
            .map((item) => {
              const label = item.name ?? item.title;

              if (getUrl) {
                return `<li><a href="${getUrl(item)}">${label}</a></li>`;
              }

              return `<li>${label}</li>`;
            })
            .join("")}
        </ul>
      `;
    };

    const openPopup = () => {
      popup.classList.remove("hidden");
    };

    const closePopup = () => {
      popup.classList.add("hidden");
    };

    const updatePopup = (node) => {
      const type = node.data("type");
      const rawId = node.id();

      if (type === "project") {
        const projectId = rawId.replace("project-", "");
        const project = findProject(projectId);
        const parentProject = project.parentProject
          ? findProject(project.parentProject)
          : null;

        const dependencyProjects =
          project.dependsOn?.map(findProject).filter(Boolean) ?? [];

        const relatedDomains = project.domains?.map(findDomain).filter(Boolean) ?? [];
        const relatedSkills = project.skills?.map(findSkill).filter(Boolean) ?? [];
        const relatedTools = project.tools?.map(findTool).filter(Boolean) ?? [];
        const relatedTechnologies =
          project.technologies?.map(findTechnology).filter(Boolean) ?? [];
        const relatedThinking =
          project.thinking?.map(findThinking).filter(Boolean) ?? [];
        const relatedArtifacts =
          project.artifacts?.map(findArtifact).filter(Boolean) ?? [];
        const relatedQualifications =
          project.qualifications?.map(findQualification).filter(Boolean) ?? [];

        popupContent.innerHTML = `
          <p class="panel-eyebrow">Project</p>
          <h2>${project.title}</h2>
          <p>${project.summary ?? "No summary added yet."}</p>

          <h3>Domains</h3>
          ${listHtml(relatedDomains, (item) => `/domains/${item.id}`)}

          <h3>Skills</h3>
          ${listHtml(relatedSkills, (item) => `/skills/${item.id}`)}

          <h3>Tools</h3>
          ${listHtml(relatedTools)}

          <h3>Technologies</h3>
          ${listHtml(relatedTechnologies)}

          <h3>Thinking Themes</h3>
          ${listHtml(relatedThinking)}

          <h3>Evidence</h3>
          ${listHtml(relatedArtifacts)}

          ${parentProject ? `
            <h3>Part of</h3>
            ${listHtml([parentProject], (item) => `/projects/${item.id}`)}
          ` : ""}

          ${dependencyProjects.length ? `
            <h3>Depends on</h3>
            ${listHtml(dependencyProjects, (item) => `/projects/${item.id}`)}
          ` : ""}

          <h3>Qualifications</h3>
          ${listHtml(relatedQualifications)}

          <a class="panel-link" href="/projects/${project.id}">Open project page →</a>
        `;

        openPopup();
      }

      if (type === "domain") {
        const domainId = rawId.replace("domain-", "");
        const domain = findDomain(domainId);

        const relatedProjects = graphData.projects.filter((project) =>
          project.domains?.includes(domain.id)
        );

        const relatedSkillIds = [
          ...new Set(relatedProjects.flatMap((project) => project.skills ?? [])),
        ];

        const relatedSkills = relatedSkillIds.map(findSkill).filter(Boolean);

        popupContent.innerHTML = `
          <p class="panel-eyebrow">Domain</p>
          <h2>${domain.name}</h2>
          <p>${domain.description ?? "No description added yet."}</p>

          <h3>Related Projects</h3>
          ${listHtml(relatedProjects, (item) => `/projects/${item.id}`)}

          <h3>Related Skills</h3>
          ${listHtml(relatedSkills, (item) => `/skills/${item.id}`)}

          <a class="panel-link" href="/domains/${domain.id}">Open domain page →</a>
        `;

        openPopup();
      }

      if (type === "skill") {
        const skillId = rawId.replace("skill-", "");
        const skill = findSkill(skillId);

        const relatedProjects = graphData.projects.filter((project) =>
          project.skills?.includes(skill.id)
        );

        const relatedDomainIds = [
          ...new Set(relatedProjects.flatMap((project) => project.domains ?? [])),
        ];

        const relatedDomains = relatedDomainIds.map(findDomain).filter(Boolean);

        popupContent.innerHTML = `
          <p class="panel-eyebrow">Skill</p>
          <h2>${skill.name}</h2>
          <p>${skill.summary ?? "This skill is evidenced through the related projects and domains below."}</p>

          <h3>Evidence Projects</h3>
          ${listHtml(relatedProjects, (item) => `/projects/${item.id}`)}

          <h3>Related Domains</h3>
          ${listHtml(relatedDomains, (item) => `/domains/${item.id}`)}

          <a class="panel-link" href="/skills/${skill.id}">Open skill page →</a>
        `;

        openPopup();
      }

      if (type === "tool") {
        const toolId = rawId.replace("tool-", "");
        const tool = findTool(toolId);

        const relatedProjects = graphData.projects.filter((project) =>
          project.tools?.includes(tool.id)
        );

        popupContent.innerHTML = `
          <p class="panel-eyebrow">Tool</p>
          <h2>${tool.name}</h2>
          <p>${tool.summary ?? "This tool appears in the related project work below."}</p>

          <h3>Related Projects</h3>
          ${listHtml(relatedProjects, (item) => `/projects/${item.id}`)}
        `;

        openPopup();
      }

      if (type === "technology") {
        const technologyId = rawId.replace("technology-", "");
        const technology = findTechnology(technologyId);

        const relatedProjects = graphData.projects.filter((project) =>
          project.technologies?.includes(technology.id)
        );

        popupContent.innerHTML = `
          <p class="panel-eyebrow">Technology</p>
          <h2>${technology.name}</h2>
          <p>${technology.summary ?? "This technology appears in the related project work below."}</p>

          <h3>Related Projects</h3>
          ${listHtml(relatedProjects, (item) => `/projects/${item.id}`)}
        `;

        openPopup();
      }

      if (type === "thinking") {
        const thinkingId = rawId.replace("thinking-", "");
        const theme = findThinking(thinkingId);

        const relatedProjects = graphData.projects.filter((project) =>
          project.thinking?.includes(theme.id)
        );

        popupContent.innerHTML = `
          <p class="panel-eyebrow">Thinking Theme</p>
          <h2>${theme.name}</h2>
          <p>${theme.summary ?? "This theme appears across the related project work below."}</p>

          <h3>Related Projects</h3>
          ${listHtml(relatedProjects, (item) => `/projects/${item.id}`)}
        `;

        openPopup();
      }

      if (type === "artifact") {
        const artifactId = rawId.replace("artifact-", "");
        const artifact = findArtifact(artifactId);

        const relatedProjects = graphData.projects.filter((project) =>
          project.artifacts?.includes(artifact.id)
        );

        const visibilityLabel =
          artifact.visibility === "public"
            ? "Public"
            : artifact.visibility === "redacted"
              ? "Redacted"
              : "Private";

        popupContent.innerHTML = `
          <p class="panel-eyebrow">Evidence</p>
          <h2>${artifact.name}</h2>
          <p>${artifact.summary ?? "Evidence connected to related project work."}</p>

          <h3>Status</h3>
          <p>${artifact.status ?? "Not specified"}</p>

          <h3>Visibility</h3>
          <p>${visibilityLabel}</p>

          <h3>Related Projects</h3>
          ${listHtml(relatedProjects, (item) => `/projects/${item.id}`)}

          ${
            artifact.url
              ? `<a class="panel-link" href="${artifact.url}">Open evidence →</a>`
              : ""
          }
        `;

        openPopup();
      }

      if (type === "qualification") {
        const qualificationId = rawId.replace("qualification-", "");
        const qualification = findQualification(qualificationId);

        const relatedProjects = graphData.projects.filter((project) =>
          project.qualifications?.includes(qualification.id)
        );

        popupContent.innerHTML = `
          <p class="panel-eyebrow">Qualification</p>
          <h2>${qualification.name}</h2>
          <p>${qualification.summary ?? "Qualification connected to related project work."}</p>

          ${
            qualification.institution
              ? `<h3>Institution</h3><p>${qualification.institution}</p>`
              : ""
          }

          ${
            qualification.awarded
              ? `<h3>Awarded</h3><p>${qualification.awarded}</p>`
              : ""
          }

          <h3>Related Projects</h3>
          ${listHtml(relatedProjects, (item) => `/projects/${item.id}`)}
        `;

        openPopup();
      }
    };

    const resetGraph = () => {
      cy.elements().removeClass("faded");
      cy.elements().removeClass("highlighted");
      cy.elements().removeClass("search-match");
      closePopup();
    };

    const getMatchingNode = (query) => {
      return cy.nodes().filter((node) => {
        const label = node.data("label")?.toLowerCase() ?? "";
        return label.includes(query);
      })[0];
    };

    const highlightNode = (node, isSearch = false) => {
      cy.elements().removeClass("highlighted");
      cy.elements().removeClass("search-match");
      cy.elements().addClass("faded");

      const neighborhood = node.closedNeighborhood();

      neighborhood.removeClass("faded");
      neighborhood.addClass("highlighted");

      node.removeClass("faded");
      node.addClass("highlighted");

      if (isSearch) {
        node.addClass("search-match");
      }

      updatePopup(node);
    };

    const centreNode = (node) => {
      cy.stop();

      cy.animate({
        center: {
          eles: node,
        },
        zoom: 1.15,
        duration: 300,
      });
    };

    let lastTappedNode = null;
    let lastTapTime = 0;
    let draggedNode = false;

    cy.on("drag", "node", function () {
      draggedNode = true;
    });

    cy.on("tap", "node", function (event) {
      if (draggedNode) {
        draggedNode = false;
        return;
      }

      const node = event.target;
      const currentTime = Date.now();

      const isDoubleClick =
        lastTappedNode === node.id() && currentTime - lastTapTime < 500;

      lastTappedNode = node.id();
      lastTapTime = currentTime;

      if (isDoubleClick) {
        const type = node.data("type");
        const rawId = node.id();
        const id = rawId.replace(`${type}-`, "");

        const routes = {
          project: "/projects/",
          domain: "/domains/",
          skill: "/skills/",
        };

        if (routes[type]) {
          window.location.href = `${routes[type]}${id}`;
          return;
        }

        if (type === "artifact") {
          const artifact = findArtifact(id);

          if (artifact?.visibility === "public" && artifact?.url) {
            window.open(artifact.url, "_blank");
          }

          return;
        }

        return;
      }

      searchInput.value = "";
      highlightNode(node);
    });

    cy.on("tap", function (event) {
      if (event.target === cy) {
        searchInput.value = "";
        resetGraph();
      }
    });

    searchInput.addEventListener("input", function () {
      const query = searchInput.value.trim().toLowerCase();

      if (!query) {
        resetGraph();
        return;
      }

      const matchingNode = getMatchingNode(query);

      if (!matchingNode) {
        cy.elements().removeClass("highlighted");
        cy.elements().removeClass("search-match");
        cy.elements().addClass("faded");

        popupContent.innerHTML = `
          <p class="panel-eyebrow">Search</p>
          <h2>No match found</h2>
          <p>Try searching for a project, domain, skill, or tool.</p>
        `;

        openPopup();
        return;
      }

      highlightNode(matchingNode, true);
    });

    searchInput.addEventListener("keydown", function (event) {
      if (event.key !== "Enter") return;

      const query = searchInput.value.trim().toLowerCase();

      if (!query) return;

      const matchingNode = getMatchingNode(query);

      if (!matchingNode) return;

      highlightNode(matchingNode, true);
      centreNode(matchingNode);
    });

    popupClose.addEventListener("click", function () {
      closePopup();
    });

    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape") {
        closePopup();
      }
    });
  }
</script>

