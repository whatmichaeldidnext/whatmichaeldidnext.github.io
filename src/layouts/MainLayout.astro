---
const { title = "Michael Charles Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body>
    <header>
      <nav>
        <a href="/">Home</a>
        <a href="/graph">Explore</a>
        <a href="/projects">Projects</a>
        <a href="/domains">Domains</a>
        <a href="/skills">Skills</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Michael Charles</p>
    </footer>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: system-ui, sans-serif;
    background: #0f172a;
    color: #e5e7eb;
  }

  header {
    border-bottom: 1px solid #334155;
    padding: 1rem 2rem;
  }

  nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  a {
    color: #93c5fd;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  footer {
    border-top: 1px solid #334155;
    padding: 1rem 2rem;
    color: #94a3b8;
  }
</style>
